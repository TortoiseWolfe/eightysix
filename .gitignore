.pnpm-store/

# Generated files (copied during build)
public/wireframes/
public/TASKS.md
public/manifest.json
/src/config/project-detected.ts
/src/config/project-detected.json
/public/rss.xml
/public/sitemap.xml

# Claude Code local settings (user-specific permissions)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# SpecKit harness scripts and templates ship with the repo so every contributor
# gets working /speckit.* commands without per-machine setup. The scripts under
# .specify/scripts/bash/ are vendored from upstream github/spec-kit with two
# ScriptHammer-specific adaptations:
#   - common.sh recurses through features/<category>/<NNN-name>/ instead of flat specs/
#   - create-new-feature.sh lands new dirs under features/_uncategorized/
# See .specify/scripts/bash/config.sh for the configurable bits.
plan
tasks
storybook-static/

# SpecKit installed extensions — payload is reinstalled via `./specify
# extension add …`. We commit a small allow-list: the registry, the
# project's wireframe-config.yml, and a hand-picked set of scripts that
# ScriptHammer ships INTO the extension (not bundled by upstream). Any
# script shipped BY the extension stays gitignored so `specify extension
# update wireframe` can overwrite it without producing a diff.
.specify/extensions/**
!.specify/extensions/
!.specify/extensions/*/
!.specify/extensions/*/wireframe-config.yml
!.specify/extensions/*/scripts/
!.specify/extensions/*/scripts/validate.py
!.specify/extensions/*/scripts/inspect-wireframes.py
# ScriptHammer-local patches to extension-shipped scripts. Extension update
# will overwrite these; re-apply the diff from git log afterwards (or better,
# upstream the change so it becomes the shipped version).
!.specify/extensions/*/scripts/generate-manifest.py
# Project-local viewer customization. viewer-config.json is pure branding;
# viewer.html carries ScriptHammer-local patches (kind grouping, status
# detection wired to .issues.md format) that aren't upstream yet. An
# extension update overwrites both; re-apply patches from git log after.
!.specify/extensions/*/viewer/
!.specify/extensions/*/viewer/viewer-config.json
!.specify/extensions/*/viewer/viewer.html
# Project-local authoring conventions doc (ScriptHammer-specific as-is
# wireframe rules). Extension-shipped; re-apply on update if wiped.
!.specify/extensions/*/AUTHORING-AS-IS.md
# Registered wireframe-extension skills. The payload is installed by
# `./specify extension add wireframe`, but we track the SKILL.md copies so
# local ScriptHammer-specific preamble (path conventions) persists across
# forks. An extension update overwrites these — re-apply from git log.
.claude/skills/speckit-wireframe-*/
!.claude/skills/speckit-wireframe-*/
!.claude/skills/speckit-wireframe-*/SKILL.md

# Brainstorm scratch (superpowers visual-companion sessions)
.superpowers/
.component-backup-*
docs/visual-testing/

# Test screenshots
screenshots/
.screenshots/
mobile-check.png

# Runtime test fixtures — created by node:test beforeEach, deleted by afterEach.
# If afterEach fails they linger; never commit them (see fixtures/README.md).
scripts/__tests__/fixtures/*
!scripts/__tests__/fixtures/README.md

# SpecKit wrapper (Docker-first) — tool + cache state, never commit
.speckit-tools/
.speckit-cache/
